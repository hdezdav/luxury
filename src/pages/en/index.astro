---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import '../../styles/global.css';

const SERVICES = [
  { href: "/en/mansiones", img: "/services/mansiones-elite.png", sublabel: "Elite Mansions", label: "Luxury Mansions" },
  { href: "/en/experiencias", img: "/services/tour.png", sublabel: "Tour Services", label: "Tours & Experiences" },
  { href: "/en/vehiculos", img: "/services/carros-de-lujo.png", sublabel: "Luxury Cars", label: "High-End Vehicles" },
  { href: "/en/yates", img: "/services/yate.png", sublabel: "Yacht Service", label: "Yachts" },
];

const BENEFITS = [
  {
    title: "Stunning luxury homes:",
    text: "Enjoy a stay in one of our luxury homes with a private pool, jacuzzi, panoramic views, and all amenities.",
  },
  {
    title: "Elegant cars:",
    text: "Rent a high-end vehicle and feel the thrill of driving through the city in style.",
  },
  {
    title: "Luxurious yachts:",
    text: "Embark on an unforgettable journey aboard a luxury yacht and explore the most paradisiacal coasts.",
  },
];

const WHY_US_LIST = [
  {
    title: "Access to a wide selection of luxury properties:",
    text: "We have a wide variety of luxury homes, cars, and yachts to choose from, so you can find the perfect accommodation for your needs.",
  },
  {
    title: "Personalized service:",
    text: "A team of travel experts is at your disposal to help you plan your perfect trip and cater to all your needs.",
  },
  {
    title: "Attention to detail:",
    text: "We care about the smallest details so your travel experience is flawless.",
  },
  {
    title: "Commitment to excellence:",
    text: "We are committed to providing the highest quality service to make your trip unforgettable.",
  },
];

const REASONS = [
  { title: "Experience", text: "We have years of experience in the luxury tourism industry." },
  { title: "Trust", text: "We are a recognized and trusted company with an excellent reputation." },
  { title: "Flexibility", text: "We can tailor our services to your specific needs." },
  { title: "Passionate", text: "We are passionate about luxury and travel, and we want to share that passion with you." },
];

const WEDDING_STEPS = [
  { title: "Request a no-obligation quote:", body: "Contact us and tell us your ideas for your ideal bachelor/bachelorette party." },
  { title: "We design the perfect experience for you:", body: "We will help you choose the destination, activities, and accommodation that best suit your needs." },
  { title: "Live an unforgettable bachelor party:", body: "Create memories that will stay with you for a lifetime." },
];
---

<Layout title="Luxury Travel Home — Experience Limitless Luxury">
  <Navbar />
  <WhatsAppFloat />

  <!-- ═══ HERO ═══════════════════════════════════════ -->
  <header class="hero" id="home">
    <div class="hero__bg">
      <img src="/services/mansiones-elite.png" alt="Luxury mansions in Medellin" loading="eager" />
    </div>
    <div class="hero__overlay"></div>

    <div class="container hero__content">
      <p class="overline fade-up mb-6">Luxury Travel Home · Medellin, Colombia</p>
      <h1 class="fade-up-1 mb-6">
        Experience luxury<br />
        <span class="gold-shimmer">without limits</span>
      </h1>
      <p class="hero__subtitle fade-up-2 mb-8">
        High-value rentals in the city: Luxury homes for rent in Medellin.<br />
        Relax and enjoy your stay in one of our luxury homes in Medellin.
      </p>
      <div class="fade-up-3">
        <a href="/en/mansiones" class="btn btn--gold">Luxury Mansions</a>
      </div>
    </div>

    <div class="hero__scroll">
      <span class="overline" style="font-size:0.5rem;">scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </header>

  <!-- ═══ WHY CHOOSE US ═════════════════════════════ -->
  <section class="section section--alt" id="why-choose-us">
    <div class="container">
      <div class="text-center mb-16 reveal">
        <p class="overline mb-3">Luxury Travel Home</p>
        <h2>Why choose us?</h2>
        <div class="accent-line accent-line--center"></div>
      </div>

      <div class="why-grid">
        <div class="why-text reveal">
          <p class="mb-8" style="line-height:1.95;">
            At Luxury Travel Home, we specialize in creating unique and unforgettable travel experiences
            for our most demanding clients. We offer a wide range of luxury services, including:
          </p>

          <ul class="benefit-list mb-8">
            {BENEFITS.map((b) => (
              <li class="benefit-item">
                <span class="benefit-diamond">◆</span>
                <div>
                  <p class="font-semibold text-sm mb-1" style="color:var(--fg);">{b.title}</p>
                  <p class="text-sm leading-relaxed">{b.text}</p>
                </div>
              </li>
            ))}
          </ul>

          <div class="border-top pt-8 mb-8">
            <p style="line-height:1.95;" class="mb-4">
              Our mission is to make our clients' dreams come true. With personalized service
              and attention to detail, we are committed to providing a travel experience that exceeds
              all your expectations.
            </p>
            <p style="line-height:1.95;">By choosing Luxury Travel Home, you can enjoy:</p>
          </div>

          <ul class="dash-list mb-8">
            {WHY_US_LIST.map((item) => (
              <li class="dash-item">
                <span class="dash-line"></span>
                <span>
                  <strong class="font-medium" style="color:var(--fg);">{item.title}</strong>{" "}
                  {item.text}
                </span>
              </li>
            ))}
          </ul>

          <p class="border-top pt-8 text-center font-medium text-gold" style="font-size: 1rem;">
            Welcome to a world of exclusivity and elegance with Luxury Travel Home!
          </p>
        </div>

        <div class="why-image reveal">
          <div class="why-image__wrap">
            <img src="/services/mansiones-elite.png" alt="Luxury mansion in Medellin" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MORE REASONS ══════════════════════════════ -->
  <section class="section reasons-section">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <p class="overline mb-3">More reasons to choose us</p>
        <div class="accent-line accent-line--center"></div>
      </div>

      <div class="grid-4">
        {REASONS.map((r) => (
          <div class="reason-card card reveal">
            <div class="reason-card__body">
              <span class="reason-card__line"></span>
              <h3>{r.title}</h3>
              <p class="text-sm leading-relaxed">{r.text}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center text-sm leading-relaxed max-w-2xl mx-auto mt-12 reveal">
        If you are looking for a unique and unforgettable travel experience,{" "}
        <strong class="font-medium text-gold">Luxury Travel Home</strong>{" "}
        is the perfect choice for you.
      </p>
    </div>
  </section>

  <!-- ═══ TEAM ══════════════════════════════════════ -->
  <section class="section section--alt" id="team">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <p class="overline mb-3">Our Team</p>
        <h2>Meet the amazing team</h2>
        <div class="accent-line accent-line--center"></div>
        <p class="text-sm mx-auto max-w-sm mt-4" style="font-style:italic;">
          "Let no one come to us without leaving better and happier"
        </p>
      </div>

      <div class="team-wrapper reveal">
        <div class="team-card card">
          <div class="team-card__img">
            <img src="/team/pablo.jpg" alt="Pedro Pablo" loading="lazy" />
            <div class="team-card__img-gradient"></div>
          </div>
          <div class="team-card__body">
            <p class="overline" style="font-size:0.55rem;">Pedro Pablo</p>
            <h3 style="font-size:1.6rem; margin-top:0.25rem;">Pedro Pablo</h3>
            <p class="overline" style="font-size:0.55rem; color:var(--fg-muted); margin-top:0.35rem;">
              Founder & Director of Experiences
            </p>
            <p class="text-xs mt-4" style="line-height:1.7;">
              Specialist in Real Estate and<br />VIP Experiences in Medellin, Colombia
            </p>
            <div class="team-card__links">
              <a href="https://www.instagram.com/ppsg_777/" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm">
                Instagram
              </a>
              <a href="https://www.airbnb.com.co/users/show/427110649" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm">
                Airbnb
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT ═══════════════════════════════════ -->
  <section class="section" id="contact">
    <div class="container text-center reveal">
      <p class="overline mb-3">Need help?</p>
      <h2>Get in touch</h2>
      <div class="accent-line accent-line--center"></div>
      <p class="text-sm leading-relaxed max-w-lg mx-auto mt-2">
        Contact us today to start planning your dream trip.
      </p>
      <div class="mt-8">
        <a href="https://wa.me/573217927739" target="_blank" rel="noopener noreferrer" class="btn btn--whatsapp">
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:1rem;height:1rem;">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Contact via WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ══════════════════════════════════ -->
  <section class="section section--alt" id="services">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <p class="overline mb-3">Luxury services in one place</p>
        <div class="accent-line accent-line--center"></div>
      </div>

      <div class="grid-4">
        {SERVICES.map((s) => (
          <a href={s.href} class="card service-card reveal">
            <div class="card__img">
              <img src={s.img} alt={s.label} loading="lazy" />
              <div class="card__img-overlay"></div>
              <div class="service-card__label">
                <p class="overline" style="font-size:0.55rem;">{s.sublabel}</p>
                <h3 style="font-size:1.1rem; line-height:1.25; margin-top:0.25rem;">{s.label}</h3>
              </div>
            </div>
            <div class="card__body text-center">
              <span class="btn btn--outline" style="width:100%; justify-content:center;">More information</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ WEDDINGS & EVENTS ═════════════════════════ -->
  <section class="section">
    <div class="container wedding-grid">
      <div class="wedding-text reveal">
        <p class="overline">Weddings & Events · Bachelor Parties</p>
        <h2 class="mt-4">Exclusivity for Weddings and more</h2>
        <div class="accent-line"></div>

        <p class="text-sm leading-loose mb-4">
          Is your wedding coming up? Don't settle for less! At Luxury Travel Home we offer you exclusive
          experiences that go beyond the ordinary. Enjoy an unforgettable getaway with your partner,
          full of pleasures and moments that will remain engraved in your memory forever.
        </p>
        <p class="text-sm leading-loose mb-6">
          Forget the limitations and immerse yourself in a world of luxury and satisfaction.
        </p>

        <div class="border-top pt-6">
          <p class="text-sm font-semibold mb-4" style="color:var(--fg);">Ready to book?</p>
          <ul class="dash-list">
            {WEDDING_STEPS.map((item) => (
              <li class="dash-item">
                <span class="dash-line"></span>
                <span>
                  <strong class="font-medium" style="color:var(--fg);">{item.title}</strong>{" "}
                  {item.body}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <div class="wedding-cta">
          <a
            href="https://wa.me/573217927739?text=Hello,%20I%20want%20to%20book%20for%20weddings%20or%20events"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--gold"
          >
            Book here
          </a>
          <span class="overline" style="font-size:0.55rem;">Bachelor party</span>
        </div>
      </div>

      <div class="wedding-image reveal">
        <div class="wedding-image__wrap">
          <img src="/services/despedida-soltera.png" alt="Luxury weddings and events" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PAYMENT METHODS ═══════════════════════════ -->
  <section class="section section--sm section--alt">
    <div class="container text-center reveal">
      <p class="overline mb-3">Payment Methods</p>
      <div class="accent-line accent-line--center"></div>
      <p class="text-sm leading-relaxed max-w-xl mx-auto mt-2">
        At Luxury Travel Home we have a wide selection of payment methods to suit your needs.
        Request more information here.
      </p>
      <div class="mt-8">
        <a
          href="https://wa.me/573217927739?text=Hello,%20I%20would%20like%20more%20information%20about%20payment%20methods"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--outline"
        >
          Contact Us Here
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ═══ HERO ═══════════════════════════════════════════ */
  .hero { position: relative; isolation: isolate; display: flex; align-items: center; justify-content: center; min-height: 100vh; overflow: hidden; padding-top: 5rem; }
  .hero__bg { position: absolute; inset: 0; z-index: -2; }
  .hero__bg img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .hero__overlay { position: absolute; inset: 0; z-index: -1; background: linear-gradient(160deg, rgba(0,0,0,0.68) 0%, rgba(5,5,5,0.85) 100%); }
  .hero__content { text-align: center; padding-block: 4rem; }
  .hero__subtitle { max-width: 36rem; margin-inline: auto; font-size: 0.95rem; line-height: 2; color: var(--fg-muted); }
  .hero__scroll { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 0.5rem; opacity: 0.45; }
  .hero__scroll-line { width: 1px; height: 2.5rem; background: var(--gold); animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }

  /* ═══ WHY US GRID ════════════════════════════════════ */
  .why-grid { display: grid; gap: 3rem; }
  @media (min-width: 1024px) { .why-grid { grid-template-columns: 1fr 1fr; gap: 4rem; } }
  .benefit-list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; }
  .benefit-item { display: flex; align-items: flex-start; gap: 1rem; }
  .benefit-diamond { flex-shrink: 0; margin-top: 0.2rem; font-size: 0.7rem; color: var(--gold); font-family: var(--font-body); letter-spacing: 0; }
  .dash-list { list-style: none; display: flex; flex-direction: column; gap: 1.25rem; }
  .dash-item { display: flex; align-items: flex-start; gap: 0.75rem; font-size: 0.875rem; color: var(--fg-muted); line-height: 1.85; }
  .dash-line { flex-shrink: 0; width: 1rem; height: 1px; background: var(--gold); margin-top: 0.7rem; }
  .why-image { display: none; }
  @media (min-width: 1024px) { .why-image { display: block; position: sticky; top: 6rem; } }
  .why-image__wrap { border-radius: var(--radius-xl); overflow: hidden; border: 1px solid var(--border); min-height: 600px; position: relative; }
  .why-image__wrap img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; }

  /* ═══ REASONS SECTION ═══════════════════════════════ */
  .reasons-section { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .reason-card { text-align: center; }
  .reason-card__body { padding: 2rem 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .reason-card__line { display: block; width: 2rem; height: 1px; background: var(--gold); }

  /* ═══ TEAM ══════════════════════════════════════════ */
  .team-wrapper { display: flex; justify-content: center; }
  .team-card { max-width: 20rem; width: 100%; text-align: center; }
  .team-card__img { position: relative; height: 20rem; overflow: hidden; }
  .team-card__img img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
  .team-card__img-gradient { position: absolute; inset: 0; background: linear-gradient(to top, rgba(5,5,5,0.95) 0%, transparent 55%); }
  .team-card__body { padding: 1.75rem 2rem 2rem; }
  .team-card__links { display: flex; justify-content: center; gap: 0.75rem; margin-top: 1.25rem; }

  /* ═══ SERVICE CARDS ═════════════════════════════════ */
  .service-card { display: block; }
  .service-card__label { position: absolute; bottom: 0; left: 0; right: 0; padding: 1.25rem; z-index: 1; }

  /* ═══ WEDDING SECTION ═══════════════════════════════ */
  .wedding-grid { display: grid; gap: 3rem; align-items: center; }
  @media (min-width: 1024px) { .wedding-grid { grid-template-columns: 1fr 1fr; gap: 4rem; } }
  .wedding-cta { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; margin-top: 1.5rem; }
  .wedding-image__wrap { border-radius: var(--radius-xl); overflow: hidden; border: 1px solid var(--border); min-height: 32rem; position: relative; }
  .wedding-image__wrap img { width: 100%; height: 100%; object-fit: cover; object-position: center; position: absolute; inset: 0; }
</style>
