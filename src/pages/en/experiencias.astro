---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import WhatsAppFloat from "../../components/WhatsAppFloat.astro";
import "../../styles/global.css";

const EXPERIENCIAS = [
  {
    name: "Helicopter Flight",
    desc: "Fly over Medellin and admire the city and its mountains from the sky with total privacy and style. A unique perspective few people experience.",
    duration: "Custom",
    group: "Up to 5 guests",
    includes: [
      "Exclusive panoramic flight",
      "Certified expert pilot",
      "VIP onboard service",
    ],
    icon: `<img src="https://www.svgrepo.com/show/20347/flying-helicopter.svg" alt="Helicopter icon" loading="lazy" />`,
    num: "01",
    image:
      "https://images.pexels.com/photos/30132648/pexels-photo-30132648.jpeg",
  },
  {
    name: "Private Jet Charter",
    desc: "Exclusive charter flights for business or leisure. Absolute comfort, total privacy, and flexible national and international routes.",
    duration: "Custom",
    group: "Tailored",
    includes: [
      "National and international routes",
      "Dedicated private crew",
      "Exclusive gourmet catering",
    ],
    icon: `<img src="https://www.svgrepo.com/show/326465/airplane-outline.svg" alt="Airplane icon" loading="lazy" />`,
    num: "02",
    image:
      "https://images.unsplash.com/photo-1619651565830-892ccdb2bd51?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  },
  {
    name: "City Tour VIP",
    desc: "Discover Medellin's best spots in a private luxury vehicle with a certified bilingual guide. Priority access and personalized service at every stop.",
    duration: "6 hours",
    group: "Up to 8 guests",
    includes: [
      "Luxury vehicle with driver",
      "Certified bilingual guide",
      "Priority access to key locations",
    ],
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>`,
    num: "03",
    image:
      "https://images.pexels.com/photos/27825960/pexels-photo-27825960.jpeg",
  },
  {
    name: "Lifestyle Cinema & Videoclips",
    desc: "Premium audiovisual production to capture your experience: videoclips, lifestyle sessions, and cinematic pieces with high-end creative direction.",
    duration: "Full day",
    group: "Solo or groups",
    includes: [
      "Creative direction",
      "Filming with pro gear",
      "Editing and final delivery",
    ],
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2"/><path d="M10 10l5 2-5 2v-4z"/></svg>`,
    num: "04",
    image:
      "https://images.pexels.com/photos/32535764/pexels-photo-32535764.jpeg",
  },
];

const STATS = [
  { value: "100%", label: "Guaranteed privacy" },
  { value: "24/7", label: "Personalized support" },
  { value: "4+", label: "Exclusive experiences" },
  { value: "★ 5.0", label: "Client rating" },
];
---

<Layout
  lang="en"
  title="Exclusive Experiences - Luxury Travel Home"
  description="Enjoy unique experiences in Medellin and Colombia: helicopter flights, private jets, and VIP tours."
>
  <Navbar />
  <WhatsAppFloat />

  <!-- HERO -->
  <header class="page-hero">
    <div class="page-hero__bg">
      <img
        src="/services/tour.png"
        alt="VIP experiences in Medellin"
        loading="eager"
      />
    </div>
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__content">
      <p class="overline fade-up mb-4">Experiences at another level</p>
      <h1 class="fade-up-1 mb-4">
        Exclusive<br /><span class="gold-shimmer">Experiences</span>
      </h1>
      <p class="page-hero__sub fade-up-2">
        Experiences designed like bespoke creations: luxury, privacy, and visual
        storytelling in every detail.
      </p>
    </div>
  </header>

  <main>
    <!-- STATS BAR -->
    <section class="stats-bar section--sm">
      <div class="container">
        <div class="stats-grid">
          {
            STATS.map((s) => (
              <div class="stat-item">
                <span class="stat-value">{s.value}</span>
                <span class="stat-label">{s.label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- INTRO -->
    <section class="section container">
      <div class="intro-grid reveal">
        <div>
          <p class="overline mb-3">Premium Services</p>
          <h2>The world within reach</h2>
          <div class="accent-line"></div>
          <p class="text-sm leading-relaxed mb-4">
            We offer a portfolio of experiences that redefine luxury. Whether
            crossing the skies in our private aircraft or exploring the most
            exclusive places in the region, every moment is designed to exceed
            your expectations.
          </p>
          <p
            class="text-sm leading-relaxed mb-6"
            style="color:var(--fg-muted);"
          >
            Every experience is fully customizable. Tell us your vision and we
            will bring it to life with the highest standards of quality and
            discretion.
          </p>
          <a
            href="https://wa.me/573217927739?text=Hello,%20I%20am%20interested%20in%20booking%20a%20VIP%20experience"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--gold">Check availability</a
          >
        </div>
        <div class="intro-img">
          <img src="/services/tour.png" alt="VIP experience" loading="lazy" />
          <div class="intro-img__badge">
            <span class="overline" style="font-size:0.52rem;">Only for you</span
            >
            <p
              style="font-size:0.8rem; font-weight:600; color:var(--fg); margin:0;"
            >
              Tailored experiences
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- VISUAL MOSAIC -->
    <section class="section container section--sm">
      <div class="mosaic-head text-center reveal">
        <p class="overline mb-3">Visual Direction</p>
        <h2>Your experience storyboard</h2>
        <div class="accent-line accent-line--center"></div>
      </div>
      <div class="exp-mosaic reveal">
        <article class="mosaic-slot mosaic-slot--main">
          <span class="mosaic-slot__chip">Hero</span>
          <img
            src="https://images.pexels.com/photos/30132648/pexels-photo-30132648.jpeg"
            alt="Hero view of helicopter experience"
            loading="lazy"
          />
          <p>Helicopter flight</p>
        </article>
        <article class="mosaic-slot">
          <span class="mosaic-slot__chip">Detail</span>
          <img
            src="https://images.pexels.com/photos/27825960/pexels-photo-27825960.jpeg"
            alt="City tour VIP"
            loading="lazy"
          />
          <p>City Tour VIP</p>
        </article>
        <article class="mosaic-slot">
          <span class="mosaic-slot__chip">Behind the scenes</span>
          <img
            src="https://images.pexels.com/photos/32535764/pexels-photo-32535764.jpeg"
            alt="Lifestyle cinema audiovisual production"
            loading="lazy"
          />
          <p>Lifestyle Cinema</p>
        </article>
      </div>
    </section>

    <!-- EXPERIENCES GRID -->
    <section class="section section--alt">
      <div class="container">
        <div class="text-center mb-16 reveal">
          <p class="overline mb-3">Portfolio</p>
          <h2>Our Experiences</h2>
          <div class="accent-line accent-line--center"></div>
          <p
            class="text-sm max-w-xl mx-auto mt-4"
            style="color:var(--fg-muted); line-height:1.85;"
          >
            Four unique experiences designed for those who demand the best.
            Every detail, carefully orchestrated.
          </p>
        </div>

        <div class="exp-grid">
          {
            EXPERIENCIAS.map((t) => (
              <div class="exp-card reveal">
                <div class="exp-card__media">
                  <span class="exp-card__media-tag">Experience</span>
                  <img
                    src={t.image}
                    alt={`Photo of ${t.name}`}
                    loading="lazy"
                  />
                </div>
                <div class="exp-card__num">{t.num}</div>
                <div class="exp-card__icon" set:html={t.icon} />
                <h3 class="exp-card__name">{t.name}</h3>
                <p class="exp-card__desc">{t.desc}</p>
                <div class="exp-card__meta">
                  <div class="meta-pill">
                    <span class="meta-pill__lbl">Duration</span>
                    <span class="meta-pill__val">{t.duration}</span>
                  </div>
                  <div class="meta-pill">
                    <span class="meta-pill__lbl">Capacity</span>
                    <span class="meta-pill__val">{t.group}</span>
                  </div>
                </div>
                <ul class="exp-card__includes">
                  {t.includes.map((inc) => (
                    <li>
                      <svg class="inc-icon" viewBox="0 0 12 12" fill="none">
                        <circle
                          cx="6"
                          cy="6"
                          r="5"
                          stroke="currentColor"
                          stroke-width="1"
                        />
                        <path
                          d="M3.5 6l1.8 1.8L8.5 4.5"
                          stroke="currentColor"
                          stroke-width="1.2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                      <span>{inc}</span>
                    </li>
                  ))}
                </ul>
                <a
                  href={`https://wa.me/573217927739?text=Hello,%20I%20want%20information%20about%20${t.name}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="exp-card__cta btn btn--outline btn--sm"
                >
                  Request information
                </a>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA PANEL -->
    <section class="section container">
      <div class="cta-panel reveal">
        <div class="cta-panel__glow"></div>
        <div class="cta-panel__content">
          <p class="overline mb-4">Tailored experience</p>
          <h2 class="mb-4">We design the<br />perfect adventure for you</h2>
          <div class="accent-line accent-line--center"></div>
          <p class="text-sm leading-relaxed max-w-lg mx-auto mb-8">
            Contact us and tell us what you want to live. Our team will create
            an exclusive itinerary with the privacy and luxury you deserve.
          </p>
          <a
            href="https://wa.me/573217927739?text=Hello,%20I%20want%20to%20design%20a%20VIP%20experience"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--whatsapp"
          >
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              style="width:0.95rem;height:0.95rem;"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
            Contact on WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />
</Layout>

<style>
  /* PAGE HERO */
  .page-hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: flex-end;
    min-height: 65vh;
    overflow: hidden;
    padding-top: 5rem;
  }
  .page-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .page-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }
  .page-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to top,
      rgba(5, 5, 5, 0.97) 0%,
      rgba(5, 5, 5, 0.5) 55%,
      rgba(5, 5, 5, 0.25) 100%
    );
  }
  .page-hero__content {
    padding-bottom: 4rem;
  }
  .page-hero__sub {
    max-width: 42rem;
    font-size: 0.95rem;
    line-height: 1.9;
    color: var(--fg-muted);
    margin: 0;
  }

  /* STATS BAR */
  .stats-bar {
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border);
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }
  @media (min-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 1.5rem 1rem;
    border-right: 1px solid var(--border);
    text-align: center;
  }
  .stat-item:last-child {
    border-right: none;
  }
  .stat-value {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--gold);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  /* INTRO */
  .intro-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .intro-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }
  .intro-img {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--border);
    min-height: 24rem;
    position: relative;
  }
  .intro-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }
  .intro-img__badge {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    background: rgba(5, 5, 5, 0.85);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    backdrop-filter: blur(12px);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  /* VISUAL MOSAIC */
  .mosaic-head {
    margin-bottom: 2rem;
  }
  .exp-mosaic {
    display: grid;
    gap: 1rem;
  }
  @media (min-width: 960px) {
    .exp-mosaic {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }
  .mosaic-slot {
    min-height: 16rem;
    position: relative;
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding: 1.1rem;
    background:
      radial-gradient(
        120% 90% at 20% 0%,
        rgba(201, 168, 76, 0.18),
        transparent 45%
      ),
      linear-gradient(165deg, rgba(24, 23, 20, 0.9), rgba(8, 8, 7, 0.98));
  }
  .mosaic-slot img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .mosaic-slot::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(5, 5, 5, 0.9),
      rgba(5, 5, 5, 0.08)
    );
  }
  .mosaic-slot--main {
    min-height: 22rem;
  }
  .mosaic-slot__chip {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 2;
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(201, 168, 76, 0.5);
    background: rgba(5, 5, 5, 0.65);
    border-radius: 999px;
    padding: 0.28rem 0.56rem;
  }
  .mosaic-slot p {
    position: relative;
    z-index: 2;
    margin: 0;
    font-size: 0.64rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  /* EXPERIENCES GRID */
  .exp-grid {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .exp-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .exp-card {
    position: relative;
    background: linear-gradient(
      155deg,
      rgba(24, 23, 20, 0.85),
      rgba(15, 15, 13, 0.96)
    );
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2.25rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition:
      border-color 0.4s ease,
      transform 0.4s var(--ease-out),
      box-shadow 0.4s ease;
    overflow: hidden;
  }

  .exp-card__media {
    position: relative;
    min-height: 11.5rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(201, 168, 76, 0.35);
    background:
      radial-gradient(
        130% 100% at 12% 0%,
        rgba(201, 168, 76, 0.2),
        transparent 45%
      ),
      linear-gradient(160deg, rgba(33, 31, 26, 0.95), rgba(7, 7, 7, 1));
    display: flex;
    align-items: flex-end;
    padding: 0.9rem;
    overflow: hidden;
  }
  .exp-card__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .exp-card__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(6, 6, 6, 0.68),
      rgba(6, 6, 6, 0.12)
    );
    pointer-events: none;
  }
  .exp-card__media-tag {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    z-index: 2;
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(201, 168, 76, 0.55);
    border-radius: 999px;
    padding: 0.23rem 0.48rem;
    background: rgba(7, 7, 7, 0.72);
  }
  .exp-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .exp-card:hover {
    border-color: var(--border-gold);
    transform: translateY(-5px);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.5),
      0 0 0 1px var(--border-gold);
  }
  .exp-card:hover::before {
    opacity: 1;
  }

  .exp-card__num {
    position: absolute;
    top: 1.5rem;
    right: 1.75rem;
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 500;
    color: var(--border);
    line-height: 1;
    letter-spacing: -0.04em;
    transition: color 0.4s ease;
    pointer-events: none;
  }
  .exp-card:hover .exp-card__num {
    color: var(--border-gold);
  }

  .exp-card__icon {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--gold);
    flex-shrink: 0;
  }
  .exp-card__icon svg {
    width: 100%;
    height: 100%;
  }
  .exp-card__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) saturate(100%) invert(79%) sepia(31%) saturate(528%)
      hue-rotate(6deg) brightness(94%) contrast(91%);
  }

  .exp-card__name {
    font-size: 1.4rem;
    line-height: 1.2;
    margin: 0;
  }

  .exp-card__desc {
    font-size: 0.85rem;
    line-height: 1.9;
    color: var(--fg-muted);
    margin: 0;
  }

  .exp-card__meta {
    display: flex;
    gap: 1rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding-block: 0.9rem;
  }

  .meta-pill {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.4rem 0.85rem;
    background: var(--bg-high);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }
  .meta-pill__lbl {
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .meta-pill__val {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--fg);
  }

  .exp-card__includes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }
  .exp-card__includes li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.825rem;
    color: var(--fg-muted);
  }
  .inc-icon {
    width: 0.85rem;
    height: 0.85rem;
    color: var(--gold);
    flex-shrink: 0;
  }

  .exp-card__cta {
    margin-top: auto;
    align-self: flex-start;
  }

  /* CTA PANEL */
  .cta-panel {
    position: relative;
    background: var(--bg-elevated);
