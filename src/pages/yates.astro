---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import '../styles/global.css';

const FEATURES = [
  { title: "Tripulación completa", desc: "Capitán, marineros y chef a bordo para una experiencia sin igual." },
  { title: "Gastronomía a bordo", desc: "Chef privado con menús personalizados y vinos seleccionados." },
  { title: "Rutas personalizadas", desc: "Itinerarios a medida en costas colombianas y el Caribe." },
  { title: "Flota premium", desc: "Yates de lujo con todas las comodidades y tecnología de punta." },
];

const SPECS = [
  "Yates de 40 a 80 pies de eslora",
  "Camarotes con baño privado",
  "Jacuzzi, áreas de sol y entretenimiento",
  "GPS y equipos de seguridad de última generación",
  "Reservas por día, fin de semana o semana completa",
];
---

<Layout title="Alquiler de Yates de Lujo en Colombia - Luxury Travel Home" description="Embárquese en un viaje inolvidable a bordo de un yate de lujo. Explore las costas más paradisíacas con Luxury Travel Home.">
  <Navbar />
  <WhatsAppFloat />

  <header class="page-hero">
    <div class="page-hero__bg"><img src="/services/yate.png" alt="Yates de lujo Colombia" loading="eager" /></div>
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__content">
      <p class="overline fade-up mb-4">Alquiler de Yates</p>
      <h1 class="fade-up-1 mb-4">Yates de Lujo</h1>
      <p class="page-hero__sub fade-up-2">Embárquese en un viaje inolvidable a bordo de un yate de lujo y explore las costas más paradisíacas.</p>
      <div class="fade-up-3" style="margin-top:1.75rem;">
        <a href="https://wa.me/573217927739?text=Hola,%20quiero%20información%20sobre%20alquiler%20de%20yates" target="_blank" rel="noopener noreferrer" class="btn btn--gold">Más información</a>
      </div>
    </div>
  </header>

  <main>
    <!-- Features 4-col -->
    <section class="section container">
      <div class="features-grid">
        {FEATURES.map((f) => (
          <div class="card feature-card reveal">
            <div class="feature-card__body">
              <span class="feature-card__line"></span>
              <h3 class="feature-card__title">{f.title}</h3>
              <p class="text-sm leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Content split -->
    <section class="section section--alt">
      <div class="container">
        <div class="content-split reveal">
          <div class="content-img">
            <img src="/services/yate.png" alt="Yate de lujo" loading="lazy" />
          </div>
          <div class="content-text">
            <p class="overline mb-3">Flota privada para travesías premium</p>
            <h2>Una experiencia en el agua como ninguna otra</h2>
            <div class="accent-line"></div>
            <p class="text-sm leading-relaxed mb-6">
              Nuestros yates están equipados con las últimas tecnologías y todas las comodidades para que su viaje sea
              perfecto. Desde lujosos camarotes hasta amplias áreas de entretenimiento a bordo.
            </p>
            <ul class="spec-list">
              {SPECS.map((s) => (
                <li class="spec-item">
                  <span class="spec-bullet"></span>
                  <span class="text-sm">{s}</span>
                </li>
              ))}
            </ul>
            <div style="display:flex; flex-wrap:wrap; gap:0.75rem; margin-top:1.75rem;">
              <a href="https://wa.me/573217927739?text=Hola,%20quiero%20reservar%20un%20yate" target="_blank" rel="noopener noreferrer" class="btn btn--gold">Reservar Yate</a>
              <a href="https://wa.me/573217927739" target="_blank" rel="noopener noreferrer" class="btn btn--outline">Consultar disponibilidad</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section container">
      <div class="cta-panel reveal">
        <p class="overline mb-4">Listos para zarpar</p>
        <h2 class="mb-4">Diseñamos tu aventura en el mar</h2>
        <div class="accent-line accent-line--center"></div>
        <p class="text-sm leading-relaxed max-w-lg mx-auto mb-8">
          Contáctanos hoy mismo y cuéntanos tus sueños. Nuestro equipo creará la travesía perfecta para ti.
        </p>
        <a href="https://wa.me/573217927739?text=Hola,%20quiero%20más%20información%20sobre%20yates%20de%20lujo" target="_blank" rel="noopener noreferrer" class="btn btn--whatsapp">
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:1rem;height:1rem;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Contactar por WhatsApp
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-hero { position:relative; isolation:isolate; display:flex; align-items:flex-end; min-height:62vh; overflow:hidden; padding-top:5rem; }
  .page-hero__bg { position:absolute; inset:0; z-index:-2; }
  .page-hero__bg img { width:100%; height:100%; object-fit:cover; object-position:center 40%; }
  .page-hero__overlay { position:absolute; inset:0; z-index:-1; background:linear-gradient(to top, rgba(5,5,5,0.95) 0%, rgba(5,5,5,0.5) 55%, rgba(5,5,5,0.3) 100%); }
  .page-hero__content { padding-bottom:3.5rem; }
  .page-hero__sub { max-width:36rem; font-size:0.95rem; line-height:1.85; color:var(--fg-muted); margin:0; }

  .features-grid { display:grid; gap:1.5rem; }
  @media (min-width:640px) { .features-grid { grid-template-columns:repeat(2,1fr); } }
  @media (min-width:1024px) { .features-grid { grid-template-columns:repeat(4,1fr); } }

  .feature-card__body { padding:2rem 1.5rem; display:flex; flex-direction:column; gap:1rem; }
  .feature-card__line { display:block; width:2rem; height:1px; background:var(--gold); }
  .feature-card__title { font-size:1.15rem; }

  .content-split { display:grid; gap:3rem; align-items:center; }
  @media (min-width:1024px) { .content-split { grid-template-columns:1fr 1fr; gap:4rem; } }
  .content-img { border-radius:var(--radius-xl); overflow:hidden; border:1px solid var(--border); min-height:26rem; position:relative; }
  .content-img img { width:100%; height:100%; object-fit:cover; position:absolute; inset:0; }

  .spec-list { list-style:none; display:flex; flex-direction:column; gap:0.65rem; }
  .spec-item { display:flex; align-items:flex-start; gap:0.75rem; }
  .spec-bullet { width:1rem; height:1px; background:var(--gold); flex-shrink:0; margin-top:0.6rem; }

  .cta-panel { background:var(--bg-elevated); border:1px solid var(--border); border-radius:var(--radius-xl); padding:clamp(2.5rem,6vw,4rem); text-align:center; }
</style>
