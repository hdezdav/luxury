---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import '../styles/global.css';

import propiedades from '../data/propiedades.json';

// Filtrar para asegurarse de que tengan imagen y URL
const validProperties = propiedades.filter(p => p.thumbnail && p.url);
---

<Layout
  title="Mansiones de Lujo en Medellín - Luxury Travel Home"
  description="Casas de lujo en alquiler en Medellín. Hospedaje exclusivo lleno de lujo y elegancia. Piscinas privadas, jacuzzi y vistas panorámicas."
>
  <Navbar />
  <WhatsAppFloat />

  <!-- HERO -->
  <header class="page-hero">
    <div class="page-hero__bg">
      <img src="/services/mansiones-elite.png" alt="Casas de lujo en Medellín" loading="eager" />
    </div>
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__content">
      <p class="overline fade-up mb-4">Luxury Travel Home</p>
      <h1 class="fade-up-1 mb-4">Mansiones de Lujo</h1>
      <p class="page-hero__sub fade-up-2">
        Casas de Lujo - Hospedaje exclusivo, lleno de lujo y elegancia en Medellín, Colombia.
      </p>
    </div>
  </header>

  <!-- MAIN -->
  <main class="container section">

    <!-- Section header -->
    <div class="section-header reveal">
      <div>
        <h2>Nuestras Propiedades</h2>
        <p class="text-sm text-muted mt-1">{validProperties.length} propiedades exclusivas disponibles</p>
      </div>
      <a
        href="https://wa.me/573217927739?text=Hola,%20quiero%20información%20sobre%20las%20mansiones%20disponibles"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--outline"
      >
        Consultar disponibilidad
      </a>
    </div>

    <!-- Villa grid -->
    <div class="villa-grid">
      {validProperties.map((v) => (
        <article class="card villa-card reveal">
          <div class="villa-card__img">
            <img src={v.thumbnail} alt={v.title || "Mansión Exclusiva"} loading="lazy" />
            <div class="villa-card__overlay"></div>
            {v.rating && v.rating.guestSatisfaction && (
              <span class="villa-card__tag">★ {v.rating.guestSatisfaction} / 5</span>
            )}
            <div class="villa-card__title">
              <h3>{v.title || "Mansión Exclusiva"}</h3>
            </div>
          </div>
          <div class="villa-card__body">
            <div class="villa-card__actions mt-auto">
              <a
                href={v.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--outline villa-card__cta"
              >
                Ver en Airbnb
              </a>
              <a
                href={`https://wa.me/573217927739?text=Hola,%20estoy%20interesado%20en%20la%20propiedad%20${v.title || "Mansión Exclusiva"}%20(${v.url})`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--gold villa-card__cta"
              >
                WhatsApp
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA banner -->
    <div class="cta-banner reveal">
      <div class="cta-banner__text">
        <p class="overline mb-3">Agenda una visita</p>
        <h2>Encuentra tu mansión ideal</h2>
        <div class="accent-line"></div>
        <p class="text-sm leading-relaxed max-w-xl">
          Nuestro equipo está disponible para asesorarte y ayudarte a elegir la propiedad perfecta según tus necesidades y presupuesto.
        </p>
      </div>
      <div class="cta-banner__actions">
        <a
          href="https://wa.me/573217927739?text=Hola,%20quiero%20agendar%20una%20visita%20a%20una%20mansión"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--whatsapp"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:1rem;height:1rem;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Contactar por WhatsApp
        </a>
        <a href="/" class="btn btn--outline">Volver al inicio</a>
      </div>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Page Hero ─────────────────────────────── */
  .page-hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: flex-end;
    min-height: 58vh;
    overflow: hidden;
    padding-top: 5rem;
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .page-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .page-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to top,
      rgba(5, 5, 5, 0.95) 0%,
      rgba(5, 5, 5, 0.55) 55%,
      rgba(5, 5, 5, 0.35) 100%
    );
  }

  .page-hero__content { padding-bottom: 3.5rem; }

  .page-hero__sub {
    max-width: 36rem;
    font-size: 0.95rem;
    line-height: 1.85;
    color: var(--fg-muted);
    margin: 0;
  }

  /* ── Section header row ─────────────────── */
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1.75rem;
    margin-bottom: 2.5rem;
  }

  /* ── Villa grid ─────────────────────────── */
  .villa-grid {
    display: grid;
    gap: 1.75rem;
    margin-bottom: 5rem;
  }

  @media (min-width: 640px) {
    .villa-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .villa-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .villa-card { display: flex; flex-direction: column; }

  .villa-card__img {
    position: relative;
    height: 16rem;
    overflow: hidden;
  }

  .villa-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .villa-card:hover .villa-card__img img { transform: scale(1.05); }

  .villa-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.05) 60%, transparent 100%);
  }

  .villa-card__tag {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    color: var(--gold);
    padding: 0.35rem 0.85rem;
    border-radius: 2rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .villa-card__title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem;
  }

  .villa-card__title h3 {
    font-size: 1.2rem;
    line-height: 1.3;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
  }

  .villa-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem;
    gap: 0;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .mt-auto {
    margin-top: auto;
  }

  .villa-card__actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    width: 100%;
    margin-top: 1.5rem;
  }

  .villa-card__cta {
    width: 100%;
    padding-inline: 0.5rem;
    font-size: 0.8rem;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  /* ── CTA Banner ─────────────────────────── */
  .cta-banner {
    display: grid;
    gap: 2.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }

  @media (min-width: 768px) {
    .cta-banner {
      grid-template-columns: 1fr auto;
    }
  }

  .cta-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    flex-shrink: 0;
  }
</style>
