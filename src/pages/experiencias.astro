---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import '../styles/global.css';

const EXPERIENCIAS = [
  { name: "Vuelo en Helicóptero", desc: "Sobrevuela Medellín y admira la ciudad y sus montañas desde el cielo con total privacidad y estilo.", duration: "Personalizado", group: "Hasta 5 personas", includes: ["Vuelo panorámico", "Piloto experto", "Servicio VIP"] },
  { name: "Alquiler de Jet Privado", desc: "Vuelos chárter exclusivos para viajes de negocios o placer. Confort, privacidad y flexibilidad total.", duration: "Personalizado", group: "A medida", includes: ["Rutas nacionales e internacionales", "Tripulación privada", "Catering exclusivo"] },
  { name: "City Tour VIP", desc: "Recorre los mejores rincones de Medellín en vehículo privado de lujo, con guía especializado.", duration: "6 horas", group: "Hasta 8 personas", includes: ["Vehículo de lujo", "Guía bilingüe", "Acceso preferencial"] },
  { name: "Tour Naturaleza y Café", desc: "Excursión a las montañas de Antioquia, fincas cafeteras y paisajes naturales únicos.", duration: "8 horas", group: "Hasta 8 personas", includes: ["Transporte privado", "Degustación de café", "Experiencia local"] },
];
---

<Layout title="Experiencias Exclusivas — Luxury Travel Home" description="Vive experiencias únicas en Medellín y Colombia: vuelos en helicóptero, jets privados y tours VIP.">
  <Navbar />
  <WhatsAppFloat />

  <header class="page-hero">
    <div class="page-hero__bg"><img src="/services/tour.png" alt="Experiencias VIP Medellín" loading="eager" /></div>
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__content">
      <p class="overline fade-up mb-4">Experiencias a otro nivel</p>
      <h1 class="fade-up-1 mb-4">Experiencias Exclusivas</h1>
      <p class="page-hero__sub fade-up-2">Descubre Medellín desde el aire en helicóptero, viaja en jet privado o disfruta de nuestros tours VIP diseñados a medida.</p>
    </div>
  </header>

  <main>
    <section class="section container">
      <div class="intro-grid reveal">
        <div>
          <p class="overline mb-3">Servicios Premium</p>
          <h2>El mundo a tu alcance</h2>
          <div class="accent-line"></div>
          <p class="text-sm leading-relaxed mb-6">Ofrecemos un portafolio de experiencias que redefinen el lujo. Ya sea cruzando los cielos en nuestras aeronaves privadas o explorando los rincones más exclusivos de la región, cada momento está diseñado para superar tus expectativas.</p>
          <a href="https://wa.me/573217927739?text=Hola,%20me%20interesa%20reservar%20una%20experiencia%20VIP" target="_blank" rel="noopener noreferrer" class="btn btn--gold">Consultar Servicios</a>
        </div>
        <div class="intro-img">
          <img src="/services/tour.png" alt="Experiencia VIP" loading="lazy" />
        </div>
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <div class="text-center mb-12 reveal">
          <p class="overline mb-3">Portafolio</p>
          <h2>Nuestras Experiencias</h2>
          <div class="accent-line accent-line--center"></div>
        </div>
        <div class="tours-grid">
          {EXPERIENCIAS.map((t) => (
            <div class="card tour-card reveal">
              <div class="tour-body">
                <p class="overline" style="font-size:0.6rem;">Servicio Exclusivo</p>
                <h3 class="tour-name">{t.name}</h3>
                <p class="text-sm leading-relaxed">{t.desc}</p>
                <div class="tour-meta">
                  <div class="meta-col"><span class="meta-lbl">Duración</span><span class="meta-val">{t.duration}</span></div>
                  <div class="meta-col"><span class="meta-lbl">Capacidad</span><span class="meta-val">{t.group}</span></div>
                </div>
                <ul class="inc-list">
                  {t.includes.map((inc) => (
                    <li><span class="inc-dot"></span><span class="text-sm">{inc}</span></li>
                  ))}
                </ul>
                <a href={`https://wa.me/573217927739?text=Hola,%20quiero%20información%20sobre%20${t.name}`} target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm mt-auto">Más información</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section container">
      <div class="cta-panel reveal">
        <p class="overline mb-4">Experiencia a medida</p>
        <h2 class="mb-4">Diseñamos la aventura perfecta para ti</h2>
        <div class="accent-line accent-line--center"></div>
        <p class="text-sm leading-relaxed max-w-lg mx-auto mb-8">Contáctanos y cuéntanos qué deseas vivir. Nuestro equipo creará un itinerario exclusivo con la privacidad y el lujo que mereces.</p>
        <a href="https://wa.me/573217927739?text=Hola,%20quiero%20diseñar%20una%20experiencia%20VIP" target="_blank" rel="noopener noreferrer" class="btn btn--whatsapp">
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:1rem;height:1rem;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Contactar por WhatsApp
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-hero { position:relative; isolation:isolate; display:flex; align-items:flex-end; min-height:58vh; overflow:hidden; padding-top:5rem; }
  .page-hero__bg { position:absolute; inset:0; z-index:-2; }
  .page-hero__bg img { width:100%; height:100%; object-fit:cover; object-position:center 30%; }
  .page-hero__overlay { position:absolute; inset:0; z-index:-1; background:linear-gradient(to top, rgba(5,5,5,0.95) 0%, rgba(5,5,5,0.55) 55%, rgba(5,5,5,0.35) 100%); }
  .page-hero__content { padding-bottom:3.5rem; }
  .page-hero__sub { max-width:36rem; font-size:0.95rem; line-height:1.85; color:var(--fg-muted); margin:0; }

  .intro-grid { display:grid; gap:3rem; align-items:center; }
  @media (min-width:1024px) { .intro-grid { grid-template-columns:1fr 1fr; gap:4rem; } }
  .intro-img { border-radius:var(--radius-xl); overflow:hidden; border:1px solid var(--border); min-height:22rem; position:relative; }
  .intro-img img { width:100%; height:100%; object-fit:cover; position:absolute; inset:0; }

  .tours-grid { display:grid; gap:1.5rem; }
  @media (min-width:768px) { .tours-grid { grid-template-columns:repeat(2, 1fr); } }

  .tour-card { height:100%; }
  .tour-body { padding:1.75rem; display:flex; flex-direction:column; height:100%; gap:0.75rem; }
  .tour-name { font-size:1.4rem; margin-top:0.25rem; }
  .tour-meta { display:flex; gap:2rem; border-top:1px solid var(--border); border-bottom:1px solid var(--border); padding-block:0.875rem; }
  .meta-col { display:flex; flex-direction:column; gap:0.15rem; }
  .meta-lbl { font-size:0.58rem; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; color:var(--fg-dim); }
  .meta-val { font-size:0.82rem; font-weight:600; color:var(--fg); }
  .inc-list { list-style:none; display:flex; flex-direction:column; gap:0.5rem; margin-bottom: 1.5rem; }
  .inc-list li { display:flex; align-items:flex-start; gap:0.75rem; }
  .inc-dot { width:0.35rem; height:0.35rem; border-radius:50%; background:var(--gold); flex-shrink:0; margin-top:0.4rem; }

  .cta-panel { background:var(--bg-elevated); border:1px solid var(--border); border-radius:var(--radius-xl); padding:clamp(2.5rem,6vw,4rem); text-align:center; }
  .mt-auto { margin-top: auto; }
</style>
