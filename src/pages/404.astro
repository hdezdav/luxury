---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="Página no encontrada — Luxury Travel Home">
  <Navbar />
  <div class="error-page container text-center">
    <h1 class="error-code">404</h1>
    <h2 class="mb-4">Página no encontrada</h2>
    <div class="accent-line accent-line--center"></div>
    <p class="text-sm leading-relaxed max-w-lg mx-auto mb-8 mt-4">
      Lo sentimos, la página que estás buscando no existe o ha sido movida.
    </p>
    <a href="/" class="btn btn--gold">Volver al Inicio</a>
  </div>
  <Footer />
</Layout>

<style>
  .error-page {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding-top: 5rem;
  }
  .error-code {
    font-size: 8rem;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 1rem;
    text-shadow: 0 4px 12px rgba(222, 184, 135, 0.2);
  }
</style>
