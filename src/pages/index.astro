---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import '../styles/global.css';
import propiedades from '../data/propiedades.json';
const mansionImages = propiedades.map(p => p.thumbnail).filter(Boolean).slice(0, 8);

const SERVICES = [
  { href: "/mansiones", img: "/services/mansiones-elite.png", sublabel: "Propiedades exclusivas", label: "Renta de Mansiones", id: "mansiones-card" },
  { href: "/vehiculos", img: "/services/carros-de-lujo.png",  sublabel: "Transporte VIP",   label: "Vehículos de Alta Gama" },
  { href: "/yates",     img: "/services/yate.png",            sublabel: "Servicio Premium",     label: "Yates" },
  { href: "/experiencias",     img: "/services/tour.png",            sublabel: "Tours y eventos", label: "Experiencias" },
];

const BENEFITS = [
  {
    title: "Impresionantes casas de lujo:",
    text: "Disfrute de una estancia en una de nuestras casas de lujo con piscina privada, jacuzzi, vista panorámica y todas las comodidades.",
  },
  {
    title: "Elegantes autos:",
    text: "Alquile un vehículo de alta gama y sienta la emoción de conducir por la ciudad con estilo.",
  },
  {
    title: "Lujosos yates:",
    text: "Embárquese en un viaje inolvidable a bordo de un yate de lujo y explore las costas más paradisíacas.",
  },
];

const WHY_US_LIST = [
  {
    title: "Acceso a una amplia selección de propiedades de lujo:",
    text: "Contamos con una amplia variedad de casas de lujo, autos y yates para elegir, para que pueda encontrar el alojamiento perfecto para sus necesidades.",
  },
  {
    title: "Servicio personalizado:",
    text: "Un equipo de expertos en viajes está a su disposición para ayudarle a planificar su viaje perfecto y atender a todas sus necesidades.",
  },
  {
    title: "Atención al detalle:",
    text: "Nos preocupamos por los más mínimos detalles para que su experiencia de viaje sea impecable.",
  },
  {
    title: "Compromiso con la excelencia:",
    text: "Estamos comprometidos a proporcionar un servicio de la más alta calidad para que su viaje sea inolvidable.",
  },
];

const REASONS = [
  { title: "Experiencia",  text: "Contamos con años de experiencia en la industria del turismo de lujo." },
  { title: "Confianza",    text: "Somos una empresa reconocida y confiable con una excelente reputación." },
  { title: "Flexibilidad", text: "Podemos adaptar nuestros servicios a sus necesidades específicas." },
  { title: "Apasionados",  text: "Nos apasiona el lujo y el viaje, y queremos compartir esa pasión con usted." },
];

const WEDDING_STEPS = [
  { title: "Solicita un presupuesto sin compromiso:", body: "Contáctanos y cuéntanos tus ideas para tu despedida de soltero ideal." },
  { title: "Diseñamos la experiencia perfecta para ti:", body: "Te ayudaremos a elegir el destino, las actividades y el alojamiento que mejor se adapten a tus necesidades." },
  { title: "Vive una despedida de soltero inolvidable:", body: "Crea recuerdos que te acompañarán toda la vida." },
];
---

<Layout>
  <Navbar />
  <WhatsAppFloat />

  <!-- ═══ HERO ═══════════════════════════════════════ -->
  <header class="hero" id="inicio">
    <div class="hero__bg">
      <img src="/services/mansiones-elite.png" alt="Mansiones de lujo en Medellín" loading="eager" />
    </div>
    <div class="hero__overlay"></div>

    <div class="container hero__content">
      <p class="overline fade-up mb-6">Luxury Travel Home · Medellín, Colombia</p>
      <h1 class="fade-up-1 mb-6">
        Experimenta el lujo<br />
        <span class="gold-shimmer">sin límites</span>
      </h1>
      <p class="hero__subtitle fade-up-2 mb-8">
        Renta de alto valor en Medellín: mansiones con piscina privada, jacuzzi y vistas panorámicas.<br />
        Relájate y vive una estadía que redefine el lujo.
      </p>
      <div class="fade-up-3">
        <a href="/mansiones" class="btn btn--gold">Mansiones de lujo</a>
      </div>
    </div>

    <div class="hero__scroll">
      <span class="overline" style="font-size:0.5rem;">scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </header>

  <!-- ═══ SERVICIOS (CAROUSEL) ═════════════════════════════════ -->
  <section class="section" id="servicios">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <p class="overline mb-3">Servicios de lujo en un solo lugar</p>
        <div class="accent-line accent-line--center"></div>
      </div>

      <div class="services-carousel reveal">
        {SERVICES.map((s) => (
          <a href={s.href} class="card service-card">
            <div class="card__img">
              <img 
                src={s.img} 
                alt={s.label} 
                loading="lazy" 
                id={s.id === "mansiones-card" ? "mansiones-img" : undefined}
                style={s.id === "mansiones-card" ? "transition: opacity 0.5s ease-in-out;" : ""}
              />
              <div class="card__img-overlay"></div>
              <div class="service-card__label">
                <p class="overline" style="font-size:0.55rem; color:var(--gold);">{s.sublabel}</p>
                <h3 style="font-size:1.4rem; line-height:1.25; margin-top:0.25rem;">{s.label}</h3>
              </div>
            </div>
            <div class="card__body text-center">
              <span class="btn btn--outline" style="width:100%; justify-content:center;">Más información</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script define:vars={{ mansionImages }}>
    const imgElement = document.getElementById('mansiones-img');
    if (imgElement && mansionImages.length > 0) {
      let currentIndex = 0;
      // Change image every 3.5 seconds
      setInterval(() => {
        imgElement.style.opacity = '0';
        setTimeout(() => {
          currentIndex = (currentIndex + 1) % mansionImages.length;
          imgElement.src = mansionImages[currentIndex];
          imgElement.style.opacity = '1';
        }, 500); // match CSS transition duration
      }, 3500);
    }
  </script>

  <!-- ═══ POR QUÉ ELEGIRNOS ═════════════════════════ -->
  <section class="section section--alt" id="por-que-elegirnos">
    <div class="container">
      <div class="text-center mb-16 reveal">
        <p class="overline mb-3">Luxury Travel Home</p>
        <h2>¿Por qué elegirnos?</h2>
        <div class="accent-line accent-line--center"></div>
      </div>

      <div class="why-grid">
        <!-- Text column -->
        <div class="why-text reveal">
          <p class="mb-8" style="line-height:1.95;">
            En Luxury Travel Home, nos especializamos en crear experiencias de viaje únicas e inolvidables
            para nuestros clientes más exigentes. Ofrecemos una amplia gama de servicios de lujo, incluyendo:
          </p>

          <ul class="benefit-list mb-8">
            {BENEFITS.map((b) => (
              <li class="benefit-item">
                <span class="benefit-diamond">◆</span>
                <div>
                  <p class="font-semibold text-sm mb-1" style="color:var(--fg);">{b.title}</p>
                  <p class="text-sm leading-relaxed">{b.text}</p>
                </div>
              </li>
            ))}
          </ul>

        </div>

        <!-- Image column -->
        <div class="why-image reveal">
          <div class="why-image__wrap">
            <img src="/services/mansiones-elite.png" alt="Mansión de lujo en Medellín" loading="lazy" />
          </div>
        </div>
      </div>
      </div>
    </div>
  </section>

  <!-- ═══ QUIÉNES SOMOS (EDITORIAL) ═════════════════════════ -->
  <section class="section" id="quienes-somos">
    <div class="container">
      <div class="editorial-grid">
        <!-- Recuadro / Mission Box -->
        <div class="editorial-box reveal">
          <p class="overline mb-4 text-gold">Quiénes Somos</p>
          <h2 class="mb-6">Nuestra <span class="text-gold">Misión</span></h2>
          <p class="editorial-text mb-8">
            Nuestra misión es hacer realidad los sueños de nuestros clientes. Con un servicio personalizado
            y atención al detalle, estamos comprometidos a proporcionar una experiencia de viaje que supere
            todas sus expectativas.
          </p>
          <div class="accent-line mb-8"></div>
          <p class="font-medium text-gold" style="font-size: 1.05rem; line-height: 1.6;">
            ¡Bienvenido a un mundo de exclusividad y elegancia con Luxury Travel Home!
          </p>
        </div>

        <!-- Razones Editorial -->
        <div class="editorial-content reveal">
          <p class="mb-8" style="font-size: 1.15rem; color: var(--fg); line-height: 1.8;">
            Al elegir Luxury Travel Home, usted puede disfrutar de:
          </p>
          <ul class="dash-list">
            {WHY_US_LIST.map((item) => (
              <li class="dash-item editorial-dash">
                <span class="dash-line"></span>
                <span>
                  <strong class="font-medium" style="color:var(--gold);">{item.title}</strong>{" "}
                  <span style="color: var(--fg-muted);">{item.text}</span>
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MÁS RAZONES & EQUIPO ═══════════════════════════════ -->
  <section class="section section--alt reasons-section" id="equipo">
    <div class="container">
      <div class="reasons-team-grid">
        
        <!-- Left: Más Razones -->
        <div class="reasons-block">
          <div class="text-left mb-10 reveal">
            <p class="overline mb-3">Más razones para elegirnos</p>
            <div class="accent-line"></div>
          </div>
          <div class="grid-2">
            {REASONS.map((r) => (
              <div class="reason-card card reveal" style="text-align: left;">
                <div class="reason-card__body">
                  <span class="reason-card__line" style="margin: 0 0 1.5rem 0;"></span>
                  <h3>{r.title}</h3>
                  <p class="text-sm leading-relaxed mt-2">{r.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Equipo -->
        <div class="team-block reveal">
          <div class="text-left mb-10">
            <p class="overline mb-3">Gestionado por</p>
            <div class="accent-line"></div>
          </div>
          <div class="team-wrapper" style="margin: 0;">
            <div class="team-card card">
              <div class="team-card__img">
                <img src="/team/pablo.jpg" alt="Pedro Pablo" loading="lazy" />
                <div class="team-card__img-gradient"></div>
              </div>
              <div class="team-card__body text-center">
                <h3 style="font-size:1.6rem;">Pedro Pablo</h3>
                <p class="overline" style="font-size:0.55rem; color:var(--gold); margin-top:0.4rem;">
                  Fundador &amp; Director de Experiencias
                </p>
                <p class="text-xs mt-4" style="line-height:1.7; color:var(--fg-muted);">
                  Especialista en Bienes Raíces y Experiencias VIP<br />en Medellín, Colombia
                </p>
                <div class="team-card__links justify-center mt-6">
                  <a href="https://www.instagram.com/ppsg_777/" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm">
                    Instagram
                  </a>
                  <a href="https://www.airbnb.com.co/users/show/427110649" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm">
                    Airbnb
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ BODAS & EVENTOS ═══════════════════════════ -->
  <section class="section">
    <div class="container wedding-grid">
      <!-- Text -->
      <div class="wedding-text reveal">
        <p class="overline">Bodas y Eventos · Despedidas de Soltera</p>
        <h2 class="mt-4">Exclusividad para Bodas y más</h2>
        <div class="accent-line"></div>

        <p class="text-sm leading-loose mb-4">
          ¿Tu boda se acerca? ¡No te conformes con menos! En Luxury Travel Home te ofrecemos experiencias
          exclusivas que van más allá de lo ordinario. Disfruta de una escapada inolvidable con tu pareja,
          llena de placeres y momentos que quedarán grabados en tu memoria para siempre.
        </p>
        <p class="text-sm leading-loose mb-6">
          Olvídate de las limitaciones y sumérgete en un mundo de lujo y satisfacción.
        </p>

        <div class="border-top pt-6">
          <p class="text-sm font-semibold mb-4" style="color:var(--fg);">Listo para reservar?</p>
          <ul class="dash-list">
            {WEDDING_STEPS.map((item) => (
              <li class="dash-item">
                <span class="dash-line"></span>
                <span>
                  <strong class="font-medium" style="color:var(--fg);">{item.title}</strong>{" "}
                  {item.body}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <div class="wedding-cta">
          <a
            href="https://wa.me/573217927739?text=Hola,%20quiero%20reservar%20para%20bodas%20o%20eventos"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--gold"
          >
            Reservar aquí
          </a>
          <span class="overline" style="font-size:0.55rem;">Despedida de soltera</span>
        </div>
      </div>

      <!-- Image -->
      <div class="wedding-image reveal">
        <div class="wedding-image__wrap">
          <img src="/services/despedida-soltera.png" alt="Bodas y eventos de lujo" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MÉTODOS DE PAGO ═══════════════════════════ -->
  <section class="section section--sm section--alt pay-section">
    <div class="container text-center">
      <div class="reveal">
        <p class="overline mb-3">Métodos de pago</p>
        <div class="accent-line accent-line--center"></div>
        <p class="text-sm leading-relaxed max-w-xl mx-auto mt-2">
          Aceptamos los principales métodos de pago nacionales e internacionales
          para que tu reserva sea simple y segura.
        </p>
      </div>

      <div class="pay-grid reveal">

        <!-- Bold -->
        <div class="pay-logo" title="Bold">
          <img src="https://datafonos.bold.co/wp-content/uploads/2022/12/Logo-Bold-Principal.png" alt="Bold" loading="lazy" />
        </div>

        <!-- Bancolombia -->
        <div class="pay-logo" title="Bancolombia">
          <img src="https://vectorseek.com/wp-content/uploads/2023/09/Bancolombia-Logo-Vector.svg-.png" alt="Bancolombia" loading="lazy" />
        </div>

        <!-- Bitcoin -->
        <div class="pay-logo" title="Bitcoin">
          <img src="/icons/bitcoin.svg" alt="Bitcoin" loading="lazy" />
        </div>

        <!-- Davivienda -->
        <div class="pay-logo" title="Davivienda">
          <img src="/icons/davibank.svg" alt="Davivienda" loading="lazy" />
        </div>

        <!-- Nequi -->
        <div class="pay-logo" title="Nequi">
          <img src="/icons/nequi.svg" alt="Nequi" loading="lazy" />
        </div>

        <!-- PayPal -->
        <div class="pay-logo" title="PayPal">
          <img src="/icons/paypal.svg" alt="PayPal" loading="lazy" />
        </div>

        <!-- Visa -->
        <div class="pay-logo" title="Visa">
          <img src="/icons/visa.svg" alt="Visa" loading="lazy" />
        </div>

        <!-- Western Union -->
        <div class="pay-logo" title="Western Union">
          <img src="/icons/wester.svg" alt="Western Union" loading="lazy" />
        </div>

      </div>

      <div class="reveal">
        <a
          href="https://wa.me/573217927739?text=Hola,%20quisiera%20más%20información%20sobre%20métodos%20de%20pago"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--outline"
        >
          Consultar métodos de pago
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ═══ HERO ═══════════════════════════════════════════ */
  .hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    overflow: hidden;
    padding-top: 5rem;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(160deg, rgba(0,0,0,0.68) 0%, rgba(5,5,5,0.85) 100%);
  }

  .hero__content {
    text-align: center;
    padding-block: 4rem;
  }

  .hero__subtitle {
    max-width: 36rem;
    margin-inline: auto;
    font-size: 0.95rem;
    line-height: 2;
    color: var(--fg-muted);
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.45;
  }

  .hero__scroll-line {
    width: 1px;
    height: 2.5rem;
    background: var(--gold);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* ═══ WHY US GRID ════════════════════════════════════ */
  .why-grid {
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .why-grid { grid-template-columns: 1fr 1fr; gap: 4rem; }
  }

  .benefit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .benefit-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .benefit-diamond {
    flex-shrink: 0;
    margin-top: 0.2rem;
    font-size: 0.7rem;
    color: var(--gold);
    font-family: var(--font-body);
    letter-spacing: 0;
  }

  .dash-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .dash-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
    line-height: 1.85;
  }

  .dash-line {
    flex-shrink: 0;
    width: 1rem;
    height: 1px;
    background: var(--gold);
    margin-top: 0.7rem;
  }

  .why-image {
    display: none;
  }

  @media (min-width: 1024px) {
    .why-image { display: block; position: sticky; top: 6rem; }
  }

  .why-image__wrap {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--border);
    min-height: 600px;
    position: relative;
  }

  .why-image__wrap img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; }

  /* ═══ EDITORIAL SECTION ═══════════════════════════ */
  .editorial-grid { display: grid; gap: 4rem; align-items: center; }
  @media (min-width: 1024px) { .editorial-grid { grid-template-columns: 1fr 1.2fr; gap: 5rem; } }
  .editorial-box {
    background: linear-gradient(145deg, rgba(20,20,20,0.95), rgba(5,5,5,0.95));
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-lg);
    padding: 3.5rem 2.5rem;
    position: relative;
    box-shadow: 0 15px 40px rgba(0,0,0,0.4);
    overflow: hidden;
  }
  .editorial-box::before {
    content: '';
    position: absolute;
    top: -10%; left: -10%; right: -10%; bottom: -10%;
    background: radial-gradient(circle at top right, rgba(201, 168, 76, 0.08), transparent 60%);
    pointer-events: none;
  }
  .editorial-text { font-size: 1.05rem; line-height: 1.9; color: var(--fg-muted); }
  .editorial-dash .dash-line { background: var(--border-gold); width: 1.5rem; }

  /* ═══ REASONS & TEAM SECTION ═══════════════════════════════ */
  .reasons-section { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .reasons-team-grid { display: grid; gap: 4rem; }
  @media (min-width: 768px) { .reasons-team-grid { grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; } }
  @media (min-width: 1024px) { .reasons-team-grid { grid-template-columns: 1.8fr 1fr; gap: 4rem; } }
  
  .reason-card { text-align: center; }

  .reason-card__body {
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .reason-card__line {
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--gold);
  }

  /* ═══ TEAM ══════════════════════════════════════════ */
  .team-wrapper { display: flex; justify-content: center; }

  .team-card {
    max-width: 20rem;
    width: 100%;
    text-align: center;
  }

  .team-card__img {
    position: relative;
    height: 20rem;
    overflow: hidden;
  }

  .team-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .team-card__img-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5,5,5,0.95) 0%, transparent 55%);
  }

  .team-card__body { padding: 1.75rem 2rem 2rem; }

  .team-card__links {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  /* ═══ SERVICES CAROUSEL & CARDS ═════════════════════════════════ */
  .services-carousel {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 2rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--gold-dim) var(--bg-deepest);
  }
  .services-carousel::-webkit-scrollbar { height: 6px; }
  .services-carousel::-webkit-scrollbar-track { background: var(--bg-deepest); border-radius: 4px; }
  .services-carousel::-webkit-scrollbar-thumb { background: var(--gold-dim); border-radius: 4px; }

  .service-card {
    flex: 0 0 85%;
    scroll-snap-align: start;
    min-width: 280px;
    display: block;
  }
  @media (min-width: 640px) { .service-card { flex: 0 0 45%; } }
  @media (min-width: 1024px) { .service-card { flex: 0 0 calc(25% - 1.125rem); } }

  .service-card .card__img { aspect-ratio: 3 / 4; }
  
  .service-card__label {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    right: 1.5rem;
    z-index: 2;
  }

  /* ═══ WEDDING SECTION ═══════════════════════════════ */
