---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import '../styles/global.css';

const SERVICES = [
  { href: "/mansiones", img: "/services/mansiones-elite.png", sublabel: "Mansiones Elite", label: "Mansiones Élite" },
  { href: "/experiencias",     img: "/services/tour.png",            sublabel: "Servicio de Tour", label: "Tours" },
  { href: "/vehiculos", img: "/services/carros-de-lujo.png",  sublabel: "Carros de Lujo",   label: "Carros de Alta Gama" },
  { href: "/yates",     img: "/services/yate.png",            sublabel: "Servicio Yate",     label: "Yates" },
];

const BENEFITS = [
  {
    title: "Impresionantes casas de lujo:",
    text: "Disfrute de una estancia en una de nuestras casas de lujo con piscina privada, jacuzzi, vista panorámica y todas las comodidades.",
  },
  {
    title: "Elegantes autos:",
    text: "Alquile un vehículo de alta gama y sienta la emoción de conducir por la ciudad con estilo.",
  },
  {
    title: "Lujosos yates:",
    text: "Embárquese en un viaje inolvidable a bordo de un yate de lujo y explore las costas más paradisíacas.",
  },
];

const WHY_US_LIST = [
  {
    title: "Acceso a una amplia selección de propiedades de lujo:",
    text: "Contamos con una amplia variedad de casas de lujo, autos y yates para elegir, para que pueda encontrar el alojamiento perfecto para sus necesidades.",
  },
  {
    title: "Servicio personalizado:",
    text: "Un equipo de expertos en viajes está a su disposición para ayudarle a planificar su viaje perfecto y atender a todas sus necesidades.",
  },
  {
    title: "Atención al detalle:",
    text: "Nos preocupamos por los más mínimos detalles para que su experiencia de viaje sea impecable.",
  },
  {
    title: "Compromiso con la excelencia:",
    text: "Estamos comprometidos a proporcionar un servicio de la más alta calidad para que su viaje sea inolvidable.",
  },
];

const REASONS = [
  { title: "Experiencia",  text: "Contamos con años de experiencia en la industria del turismo de lujo." },
  { title: "Confianza",    text: "Somos una empresa reconocida y confiable con una excelente reputación." },
  { title: "Flexibilidad", text: "Podemos adaptar nuestros servicios a sus necesidades específicas." },
  { title: "Apasionados",  text: "Nos apasiona el lujo y el viaje, y queremos compartir esa pasión con usted." },
];

const WEDDING_STEPS = [
  { title: "Solicita un presupuesto sin compromiso:", body: "Contáctanos y cuéntanos tus ideas para tu despedida de soltero ideal." },
  { title: "Diseñamos la experiencia perfecta para ti:", body: "Te ayudaremos a elegir el destino, las actividades y el alojamiento que mejor se adapten a tus necesidades." },
  { title: "Vive una despedida de soltero inolvidable:", body: "Crea recuerdos que te acompañarán toda la vida." },
];
---

<Layout>
  <Navbar />
  <WhatsAppFloat />

  <!-- ═══ HERO ═══════════════════════════════════════ -->
  <header class="hero" id="inicio">
    <div class="hero__bg">
      <img src="/services/mansiones-elite.png" alt="Mansiones de lujo en Medellín" loading="eager" />
    </div>
    <div class="hero__overlay"></div>

    <div class="container hero__content">
      <p class="overline fade-up mb-6">Luxury Travel Home · Medellín, Colombia</p>
      <h1 class="fade-up-1 mb-6">
        Experimenta el lujo<br />
        <span class="gold-shimmer">sin límites</span>
      </h1>
      <p class="hero__subtitle fade-up-2 mb-8">
        Renta de alto valor en Medellín: mansiones con piscina privada, jacuzzi y vistas panorámicas.<br />
        Relájate y vive una estadía que redefine el lujo.
      </p>
      <div class="fade-up-3">
        <a href="/mansiones" class="btn btn--gold">Mansiones de lujo</a>
      </div>
    </div>

    <div class="hero__scroll">
      <span class="overline" style="font-size:0.5rem;">scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </header>

  <!-- ═══ POR QUÉ ELEGIRNOS ═════════════════════════ -->
  <section class="section section--alt" id="por-que-elegirnos">
    <div class="container">
      <div class="text-center mb-16 reveal">
        <p class="overline mb-3">Luxury Travel Home</p>
        <h2>¿Por qué elegirnos?</h2>
        <div class="accent-line accent-line--center"></div>
      </div>

      <div class="why-grid">
        <!-- Text column -->
        <div class="why-text reveal">
          <p class="mb-8" style="line-height:1.95;">
            En Luxury Travel Home, nos especializamos en crear experiencias de viaje únicas e inolvidables
            para nuestros clientes más exigentes. Ofrecemos una amplia gama de servicios de lujo, incluyendo:
          </p>

          <ul class="benefit-list mb-8">
            {BENEFITS.map((b) => (
              <li class="benefit-item">
                <span class="benefit-diamond">◆</span>
                <div>
                  <p class="font-semibold text-sm mb-1" style="color:var(--fg);">{b.title}</p>
                  <p class="text-sm leading-relaxed">{b.text}</p>
                </div>
              </li>
            ))}
          </ul>

          <div class="border-top pt-8 mb-8">
            <p style="line-height:1.95;" class="mb-4">
              Nuestra misión es hacer realidad los sueños de nuestros clientes. Con un servicio personalizado
              y atención al detalle, estamos comprometidos a proporcionar una experiencia de viaje que supere
              todas sus expectativas.
            </p>
            <p style="line-height:1.95;">Al elegir Luxury Travel Home, usted puede disfrutar de:</p>
          </div>

          <ul class="dash-list mb-8">
            {WHY_US_LIST.map((item) => (
              <li class="dash-item">
                <span class="dash-line"></span>
                <span>
                  <strong class="font-medium" style="color:var(--fg);">{item.title}</strong>{" "}
                  {item.text}
                </span>
              </li>
            ))}
          </ul>

          <p class="border-top pt-8 text-center font-medium text-gold" style="font-size: 1rem;">
            ¡Bienvenido a un mundo de exclusividad y elegancia con Luxury Travel Home!
          </p>
        </div>

        <!-- Image column -->
        <div class="why-image reveal">
          <div class="why-image__wrap">
            <img src="/services/mansiones-elite.png" alt="Mansión de lujo en Medellín" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MÁS RAZONES ═══════════════════════════════ -->
  <section class="section reasons-section">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <p class="overline mb-3">Más razones para elegirnos</p>
        <div class="accent-line accent-line--center"></div>
      </div>

      <div class="grid-4">
        {REASONS.map((r) => (
          <div class="reason-card card reveal">
            <div class="reason-card__body">
              <span class="reason-card__line"></span>
              <h3>{r.title}</h3>
              <p class="text-sm leading-relaxed">{r.text}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center text-sm leading-relaxed max-w-2xl mx-auto mt-12 reveal">
        Si está buscando una experiencia de viaje única e inolvidable,{" "}
        <strong class="font-medium text-gold">Luxury Travel Home</strong>{" "}
        es la elección perfecta para usted.
      </p>
    </div>
  </section>

  <!-- ═══ EQUIPO ════════════════════════════════════ -->
  <section class="section section--alt" id="equipo">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <p class="overline mb-3">Nuestro Equipo</p>
        <h2>Conoce al increíble equipo</h2>
        <div class="accent-line accent-line--center"></div>
        <p class="text-sm mx-auto max-w-sm mt-4" style="font-style:italic;">
          "Que nadie venga a nosotros sin irse mejor y más feliz"
        </p>
      </div>

      <div class="team-wrapper reveal">
        <div class="team-card card">
          <div class="team-card__img">
            <img src="/team/pablo.jpg" alt="Pedro Pablo" loading="lazy" />
            <div class="team-card__img-gradient"></div>
          </div>
          <div class="team-card__body">
            <h3 style="font-size:1.6rem;">Pedro Pablo</h3>
            <p class="overline" style="font-size:0.55rem; color:var(--gold); margin-top:0.4rem;">
              Fundador &amp; Director de Experiencias
            </p>
            <p class="text-xs mt-4" style="line-height:1.7; color:var(--fg-muted);">
              Especialista en Bienes Raíces y Experiencias VIP<br />en Medellín, Colombia
            </p>
            <div class="team-card__links">
              <a href="https://www.instagram.com/ppsg_777/" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm">
                Instagram
              </a>
              <a href="https://www.airbnb.com.co/users/show/427110649" target="_blank" rel="noopener noreferrer" class="btn btn--outline btn--sm">
                Airbnb
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACTO ══════════════════════════════════ -->
  <section class="section" id="contacto">
    <div class="container text-center reveal">
      <p class="overline mb-3">¿Tienes alguna pregunta?</p>
      <h2>Hablemos</h2>
      <div class="accent-line accent-line--center"></div>
      <p class="text-sm leading-relaxed max-w-lg mx-auto mt-2">
        Escríbenos hoy y empieza a planificar la experiencia de lujo que mereces.
      </p>
      <div class="mt-8">
        <a href="https://wa.me/573217927739" target="_blank" rel="noopener noreferrer" class="btn btn--whatsapp">
          <svg viewBox="0 0 24 24" fill="currentColor" style="width:0.95rem;height:0.95rem;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICIOS ═════════════════════════════════ -->
  <section class="section section--alt" id="servicios">
    <div class="container">
      <div class="text-center mb-12 reveal">
        <p class="overline mb-3">Servicios de lujo en un solo lugar</p>
        <div class="accent-line accent-line--center"></div>
      </div>

      <div class="grid-4">
        {SERVICES.map((s) => (
          <a href={s.href} class="card service-card reveal">
            <div class="card__img">
              <img src={s.img} alt={s.label} loading="lazy" />
              <div class="card__img-overlay"></div>
              <div class="service-card__label">
                <p class="overline" style="font-size:0.55rem;">{s.sublabel}</p>
                <h3 style="font-size:1.1rem; line-height:1.25; margin-top:0.25rem;">{s.label}</h3>
              </div>
            </div>
            <div class="card__body text-center">
              <span class="btn btn--outline" style="width:100%; justify-content:center;">Más información</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ BODAS & EVENTOS ═══════════════════════════ -->
  <section class="section">
    <div class="container wedding-grid">
      <!-- Text -->
      <div class="wedding-text reveal">
        <p class="overline">Bodas y Eventos · Despedidas de Soltera</p>
        <h2 class="mt-4">Exclusividad para Bodas y más</h2>
        <div class="accent-line"></div>

        <p class="text-sm leading-loose mb-4">
          ¿Tu boda se acerca? ¡No te conformes con menos! En Luxury Travel Home te ofrecemos experiencias
          exclusivas que van más allá de lo ordinario. Disfruta de una escapada inolvidable con tu pareja,
          llena de placeres y momentos que quedarán grabados en tu memoria para siempre.
        </p>
        <p class="text-sm leading-loose mb-6">
          Olvídate de las limitaciones y sumérgete en un mundo de lujo y satisfacción.
        </p>

        <div class="border-top pt-6">
          <p class="text-sm font-semibold mb-4" style="color:var(--fg);">Listo para reservar?</p>
          <ul class="dash-list">
            {WEDDING_STEPS.map((item) => (
              <li class="dash-item">
                <span class="dash-line"></span>
                <span>
                  <strong class="font-medium" style="color:var(--fg);">{item.title}</strong>{" "}
                  {item.body}
                </span>
              </li>
            ))}
          </ul>
        </div>

        <div class="wedding-cta">
          <a
            href="https://wa.me/573217927739?text=Hola,%20quiero%20reservar%20para%20bodas%20o%20eventos"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--gold"
          >
            Reservar aquí
          </a>
          <span class="overline" style="font-size:0.55rem;">Despedida de soltera</span>
        </div>
      </div>

      <!-- Image -->
      <div class="wedding-image reveal">
        <div class="wedding-image__wrap">
          <img src="/services/despedida-soltera.png" alt="Bodas y eventos de lujo" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MÉTODOS DE PAGO ═══════════════════════════ -->
  <section class="section section--sm section--alt pay-section">
    <div class="container text-center">
      <div class="reveal">
        <p class="overline mb-3">Métodos de pago</p>
        <div class="accent-line accent-line--center"></div>
        <p class="text-sm leading-relaxed max-w-xl mx-auto mt-2">
          Aceptamos los principales métodos de pago nacionales e internacionales
          para que tu reserva sea simple y segura.
        </p>
      </div>

      <div class="pay-grid reveal">

        <!-- Bold -->
        <div class="pay-logo" title="Bold">
          <svg viewBox="0 0 120 48" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect width="120" height="48" rx="8" fill="#7B2FBE"/>
            <text x="60" y="31" text-anchor="middle" font-family="Arial,sans-serif" font-weight="900" font-size="22" fill="#fff" letter-spacing="-0.5">Bold</text>
          </svg>
        </div>

        <!-- Bancolombia -->
        <div class="pay-logo" title="Bancolombia">
          <svg viewBox="0 0 120 48" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect width="120" height="48" rx="8" fill="#FDDA24"/>
            <text x="60" y="20" text-anchor="middle" font-family="Arial,sans-serif" font-weight="900" font-size="9.5" fill="#1a1a1a" letter-spacing="0.3">BANCO</text>
            <text x="60" y="33" text-anchor="middle" font-family="Arial,sans-serif" font-weight="900" font-size="9.5" fill="#1a1a1a" letter-spacing="0.3">COLOMBIA</text>
          </svg>
        </div>

        <!-- Bitcoin -->
        <div class="pay-logo" title="Bitcoin">
          <svg viewBox="0 0 120 48" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect width="120" height="48" rx="8" fill="#F7931A"/>
            <text x="37" y="33" text-anchor="middle" font-family="Arial,sans-serif" font-weight="900" font-size="28" fill="#fff">₿</text>
            <text x="78" y="31" text-anchor="middle" font-family="Arial,sans-serif" font-weight="700" font-size="13" fill="#fff" letter-spacing="-0.3">Bitcoin</text>
          </svg>
        </div>

        <!-- Davivienda -->
        <div class="pay-logo" title="Davivienda">
          <svg viewBox="0 0 120 48" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect width="120" height="48" rx="8" fill="#ED1C24"/>
            <ellipse cx="26" cy="24" rx="11" ry="13" fill="#fff"/>
            <text x="72" y="31" text-anchor="middle" font-family="Arial,sans-serif" font-weight="800" font-size="12" fill="#fff" letter-spacing="-0.2">Davivienda</text>
          </svg>
        </div>

        <!-- Nequi -->
        <div class="pay-logo" title="Nequi">
          <svg viewBox="0 0 120 48" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect width="120" height="48" rx="8" fill="#5E138E"/>
            <circle cx="22" cy="24" r="11" fill="#FF3CAC"/>
            <text x="22" y="28" text-anchor="middle" font-family="Arial,sans-serif" font-weight="900" font-size="11" fill="#fff">N</text>
            <text x="74" y="31" text-anchor="middle" font-family="Arial,sans-serif" font-weight="800" font-size="17" fill="#fff" letter-spacing="0.5">nequi</text>
          </svg>
        </div>

        <!-- PayPal -->
        <div class="pay-logo" title="PayPal">
          <svg viewBox="0 0 120 48" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect width="120" height="48" rx="8" fill="#003087"/>
            <text x="60" y="32" text-anchor="middle" font-family="Arial,sans-serif" font-weight="900" font-size="20" fill="#009cde" letter-spacing="-0.5">Pay</text>
            <text x="60" y="32" text-anchor="middle" font-family="Arial,sans-serif" font-weight="900" font-size="20" fill="#fff" letter-spacing="-0.5" dx="26">Pal</text>
          </svg>
        </div>

        <!-- Visa -->
        <div class="pay-logo" title="Visa">
          <svg viewBox="0 0 120 48" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect width="120" height="48" rx="8" fill="#1A1F71"/>
            <text x="60" y="33" text-anchor="middle" font-family="Arial Black,Arial,sans-serif" font-weight="900" font-size="28" fill="#FFFFFF" letter-spacing="-1">VISA</text>
          </svg>
        </div>

        <!-- Western Union -->
        <div class="pay-logo" title="Western Union">
          <svg viewBox="0 0 120 48" xmlns="http://www.w3.org/2000/svg" fill="none">
            <rect width="120" height="48" rx="8" fill="#FDDA00"/>
            <text x="60" y="20" text-anchor="middle" font-family="Arial,sans-serif" font-weight="900" font-size="8.5" fill="#1a1a1a" letter-spacing="0.5">WESTERN</text>
            <text x="60" y="32" text-anchor="middle" font-family="Arial,sans-serif" font-weight="900" font-size="8.5" fill="#1a1a1a" letter-spacing="0.5">UNION</text>
          </svg>
        </div>

      </div>

      <div class="reveal">
        <a
          href="https://wa.me/573217927739?text=Hola,%20quisiera%20más%20información%20sobre%20métodos%20de%20pago"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--outline"
        >
          Consultar métodos de pago
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ═══ HERO ═══════════════════════════════════════════ */
  .hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    overflow: hidden;
    padding-top: 5rem;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(160deg, rgba(0,0,0,0.68) 0%, rgba(5,5,5,0.85) 100%);
  }

  .hero__content {
    text-align: center;
    padding-block: 4rem;
  }

  .hero__subtitle {
    max-width: 36rem;
    margin-inline: auto;
    font-size: 0.95rem;
    line-height: 2;
    color: var(--fg-muted);
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.45;
  }

  .hero__scroll-line {
    width: 1px;
    height: 2.5rem;
    background: var(--gold);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* ═══ WHY US GRID ════════════════════════════════════ */
  .why-grid {
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .why-grid { grid-template-columns: 1fr 1fr; gap: 4rem; }
  }

  .benefit-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .benefit-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .benefit-diamond {
    flex-shrink: 0;
    margin-top: 0.2rem;
    font-size: 0.7rem;
    color: var(--gold);
    font-family: var(--font-body);
    letter-spacing: 0;
  }

  .dash-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .dash-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
    line-height: 1.85;
  }

  .dash-line {
    flex-shrink: 0;
    width: 1rem;
    height: 1px;
    background: var(--gold);
    margin-top: 0.7rem;
  }

  .why-image {
    display: none;
  }

