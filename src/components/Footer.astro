---
const services = [
  { href: "/mansiones", label: "Mansiones de Lujo" },
  { href: "/tours", label: "Tours Exclusivos" },
  { href: "/vehiculos", label: "Vehículos Alta Gama" },
  { href: "/yates", label: "Alquiler de Yates" },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand column -->
      <div class="footer__brand">
        <img src="/brand/logo-wide.png" alt="Luxury Travel Home" width="190" height="40" class="footer__logo" />
        <p class="text-sm">
          Vive una experiencia de lujo sin límites en cada viaje. Somos tu mejor aliado en Medellín, Colombia.
        </p>
        <div class="footer__social">
          <a href="https://www.instagram.com/luxurytravelhomerentals/" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.airbnb.com.co/users/show/427110649" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="Airbnb">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.003 0C5.376 0 0 5.376 0 12.003S5.376 24.006 12.003 24.006 24.006 18.63 24.006 12.003 18.63 0 12.003 0zm5.95 16.403c-.17.552-.49 1.013-.95 1.37-.47.36-1.01.54-1.62.54-.45 0-.87-.1-1.27-.31-.4-.21-.8-.52-1.2-.92l-.29-.3-.3.3c-.4.4-.8.71-1.2.92-.4.21-.82.31-1.27.31-.61 0-1.15-.18-1.62-.54-.46-.36-.78-.82-.95-1.37-.21-.65-.19-1.37.06-2.14.2-.62.54-1.28 1.02-1.98.47-.7 1.13-1.48 1.97-2.33l2.33-2.33 2.33 2.33c.84.85 1.5 1.63 1.97 2.33.48.7.82 1.36 1.02 1.98.25.77.27 1.49.06 2.14z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <p class="overline mb-4">Servicios</p>
        <ul class="footer__list">
          {services.map((s) => (
            <li><a href={s.href}>{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <p class="overline mb-4">Contacto</p>
        <ul class="footer__list">
          <li><a href="mailto:info@luxurytravelhome.co">info@luxurytravelhome.co</a></li>
          <li><a href="https://wa.me/573217927739" target="_blank" rel="noopener noreferrer">+57 321 792 7739</a></li>
          <li>Medellín, Colombia</li>
          <li class="text-xs" style="color: var(--fg-dim);">Lun – Dom: 9:00 – 17:00</li>
        </ul>
        <a href="https://wa.me/573217927739" target="_blank" rel="noopener noreferrer" class="btn btn--whatsapp btn--sm mt-4">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="width:1rem;height:1rem;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p>Copyright &copy; 2026 Luxury Travel Home · RTN: 79391</p>
      <p>Diseñado por <span style="color: var(--fg-muted);">VizenLabs</span></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg-deepest);
    padding-top: 3.5rem;
    padding-bottom: 2rem;
    margin-top: auto;
  }

  .footer__grid {
    display: grid;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .footer__grid { grid-template-columns: 2fr 1fr 1fr; }
  }

  .footer__brand p {
    max-width: 22rem;
    line-height: 1.8;
  }

  .footer__logo {
    width: 10rem;
    height: auto;
    margin-bottom: 1rem;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .footer__social-link {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: grid;
    place-items: center;
    color: var(--fg-muted);
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .footer__social-link:hover {
    border-color: var(--gold);
    color: var(--gold);
  }
  .footer__social-link svg { width: 1rem; height: 1rem; }

  .footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .footer__list li { font-size: 0.875rem; color: var(--fg-muted); }
  .footer__list a { transition: color 0.2s ease; }
  .footer__list a:hover { color: var(--gold); }

  .footer__bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--fg-dim);
  }
  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
