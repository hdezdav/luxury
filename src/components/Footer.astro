---
export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const content = {
  es: {
    desc: "Vive una experiencia de lujo sin límites en cada viaje. Somos tu mejor aliado en Medellín, Colombia.",
    servicesTitle: "Servicios",
    services: [
      { href: "/mansiones", label: "Renta de Mansiones" },
      { href: "/vehiculos", label: "Vehículos de Alta Gama" },
      { href: "/yates", label: "Yates" },
      { href: "/experiencias", label: "Experiencias" },
    ],
    contactTitle: "Contacto",
    hours: "Lun - Dom: 9:00 - 17:00",
    designedBy: "Diseñado por",
  },
  en: {
    desc: "Experience limitless luxury on every trip. We are your best ally in Medellin, Colombia.",
    servicesTitle: "Services",
    services: [
      { href: "/en/mansiones", label: "Luxury Mansions" },
      { href: "/en/vehiculos", label: "High-End Vehicles" },
      { href: "/en/yates", label: "Yachts" },
      { href: "/en/experiencias", label: "Experiences" },
    ],
    contactTitle: "Contact",
    hours: "Mon - Sun: 9:00 AM - 5:00 PM",
    designedBy: "Designed by",
  }
};

const t = content[lang];
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand column -->
      <div class="footer__brand">
        <img src="/brand/logo-wide.png" alt="Luxury Travel Home" width="190" height="40" class="footer__logo" />
        <p class="text-sm">
          {t.desc}
        </p>
        <div class="footer__social">
          <a href="https://www.instagram.com/luxurytravelhomerentals/" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.airbnb.com.co/users/show/427110649" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="Airbnb">
            <svg viewBox="0 0 512 512" fill="currentColor"><path d="M256.4 0c-26 0-50.1 11.4-68.2 32.6-7.8 9.6-13.4 19.7-18.3 28.6l-1 1.9c-3.5 7-7.2 14.2-11.3 22.2l-.9 2C115.5 169 80 243 47.6 314.9l-2 4.4c-1.4 3-2.8 6.1-4 8.9l-1.8 3.8c-1.3 2.8-2.6 5.7-3.6 8.2-2.5 5.7-5 11.6-7.8 18.8-6.7 19.8-8.6 37.7-6 56.7 5.8 39.2 31.8 72.9 67.8 87.9 13.8 5.7 27.7 8.4 42.5 8.4 3.3 0 8.1-.3 13.6-1 17.8-2.3 35.2-8.3 51.3-17.8 18.8-10.6 37.2-25.8 57.7-47.7l.8 1.1.3-.5c19.2 20.5 37.8 36 56.6 46.9 16.4 9.6 33.7 15.6 51.2 17.8 5.7.8 10.6 1.1 14.2 1.1 14.6 0 28.7-2.8 42.1-8.6 35.7-14.3 61.6-47.3 67.8-86.3l.6-3.5c3.4-16.6 1.7-34.3-5-54-.9-2.5-1.9-5.1-2.5-6.3-1.6-4.4-3.4-8.6-4.9-11.8-1.3-3.2-2.7-6.1-4-9l-3.4-7.6c-1.1-2.6-2.2-5.1-3.4-7.6l-1.4-2.7c-35.1-77.4-71.6-153.4-108.5-226l-1.8-3.6q-5.85-10.95-12-23.7l-1.2-2.3c-4.4-7.9-8.9-16-15.6-24.1l-1-1.3C307.4 11.9 283.3 0 256.4 0m-.5 43.1c12.6-.2 25 5 33.8 15.5l2.3 2.8c4.5 5.1 7.6 10.9 11.2 17.2l1.3 2.8c3.9 7.9 8.1 16.2 12 23.3l1.5 3.1c36.7 72.1 73 147.6 107.5 223.8l3 6.8.3.3 1.4 3.2 3.8 8.6c1 2.2 2.1 4.5 3.4 7.8 1.3 3 2.8 6.4 4.7 11.3l1.6 3.9v.1c4.5 13 5.4 23.5 3.2 33l-.5 3.2c-3.6 24.6-19.6 45.4-43 54.8-6.9 3.1-15.7 4.9-24.8 4.9-2 0-4.8-.2-8.4-.7-12.1-1.5-24-5.7-35.5-12.4-16.8-9.7-33.8-24.3-51.9-44.5l1.4-1.8c29.2-38.1 47.4-72.9 54.3-103.5v-.2c3.3-15.1 3.9-29.4 2-42-1.6-12.3-6-24-12.9-34.7C312.5 206 285.9 192 256 192c-28.6 0-55.1 13.6-70.7 36.4l-1.2 2c-6.6 10.6-10.8 21.9-12.3 33.3-2.1 13.6-1.5 27.5 1.8 42.3 6.6 30.8 25.4 66.9 54.4 104.2l.9 1.1c-19.4 21.4-36 35.6-52.5 45-11.4 6.7-23.3 10.9-35.8 12.5-3.2.5-6 .6-7.9.6-9.3 0-17.6-1.6-26.1-5.2-22.3-9.3-38.4-30.2-41.9-54.5-1.7-12.1-.4-23.5 4-36.3 2.2-5.8 4.4-11 6.8-16.3 1-2.5 2.2-5 3.3-7.4l2-4.4c1.2-2.8 2.4-5.5 3.7-8.2l2.6-5.8c31.7-70.2 67-143.6 108.3-225.4l.7-1.7c3.8-7.2 7.6-14.8 11.2-22l.5-1.1c3.9-7 8.3-15 13.3-21.2 9.3-11 22.1-16.6 34.8-16.8m.1 191.6c15.1 0 28.3 6.6 35.3 17.8 3.6 5.6 5.8 11.3 6.7 17.8 1.2 7.7.7 17-1.4 26.9-5 22.6-18.7 49.1-40.7 79.1-21.7-29.4-35.7-56.6-40.5-79.4-2.2-9.7-2.7-18.4-1.3-27 .8-6 3-11.7 6.6-17.3l.4-.7c7.7-10.9 20.7-17.2 34.9-17.2"/></svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <p class="overline mb-4">{t.servicesTitle}</p>
        <ul class="footer__list">
          {t.services.map((s) => (
            <li><a href={s.href}>{s.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <p class="overline mb-4">{t.contactTitle}</p>
        <ul class="footer__list">
          <li><a href="mailto:info@luxurytravelhome.co">info@luxurytravelhome.co</a></li>
          <li><a href="https://wa.me/573217927739" target="_blank" rel="noopener noreferrer">+57 321 792 7739</a></li>
          <li>Medellín, Colombia</li>
          <li class="text-xs" style="color: var(--fg-dim);">{t.hours}</li>
        </ul>
        <a href="https://wa.me/573217927739" target="_blank" rel="noopener noreferrer" class="btn btn--whatsapp btn--sm mt-4">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="width:1rem;height:1rem;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p>Copyright &copy; 2026 Luxury Travel Home · RNT: 79391</p>
      <p>
        {t.designedBy}{" "}
        <a href="https://vizenlabs.com.co/" target="_blank" rel="noopener noreferrer" class="vizen-link">
          VizenLabs
        </a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg-deepest);
    padding-top: 3.5rem;
    padding-bottom: 2rem;
    margin-top: auto;
  }

  .footer__grid {
    display: grid;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .footer__grid { grid-template-columns: 2fr 1fr 1fr; }
  }

  .footer__brand p {
    max-width: 22rem;
    line-height: 1.8;
  }

  .footer__logo {
    width: 10rem;
    height: auto;
    margin-bottom: 1rem;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .footer__social-link {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: grid;
    place-items: center;
    color: var(--fg-muted);
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .footer__social-link:hover {
    border-color: var(--gold);
    color: var(--gold);
  }
  .footer__social-link svg { width: 1rem; height: 1rem; }

  .footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .footer__list li { font-size: 0.875rem; color: var(--fg-muted); }
  .footer__list a { transition: color 0.2s ease; }
  .footer__list a:hover { color: var(--gold); }

  .footer__bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--fg-dim);
  }
  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .vizen-link {
    color: var(--gold);
    font-weight: 500;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }
  .vizen-link:hover {
    color: #fff;
    text-shadow: 0 0 8px rgba(212, 175, 55, 0.4);
  }
</style>
